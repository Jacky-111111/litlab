# Backend
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
CORS_ORIGINS=http://127.0.0.1:8001,http://localhost:8001,http://[::]:8001,http://[::1]:8001

# Public origin of the LitLab frontend. Used when the backend needs to build
# absolute URLs it can't infer from the request — in particular, the share-link
# QR endpoint (/shared/c/{slug}/qr.png) encodes `${FRONTEND_ORIGIN}/shared-
# collection.html?slug=...` into the image. Clients may also pass ?origin=...
# on the query string to override this (handy in local dev).
FRONTEND_ORIGIN=http://localhost:8001
